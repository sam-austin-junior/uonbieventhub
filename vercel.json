{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "functions": {
    "src/app/api/admin/events/[eventId]/knowledge/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/e/[slug]/certificate/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/admin/events/[eventId]/announcements/route.ts": {
      "maxDuration": 60
    }
  }
}
