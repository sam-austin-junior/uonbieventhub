generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Required by Supabase: DATABASE_URL points at the pooler (port 6543);
  // DIRECT_URL points at the direct connection (port 5432) for migrations.
  // Locally this can be omitted — Prisma falls back to url.
  directUrl = env("DIRECT_URL")
}

enum Role {
  ATTENDEE
  ORGANIZER
  ADMIN
  SUPERADMIN
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SessionFormat {
  IN_PERSON
  VIRTUAL
  HYBRID
  ON_DEMAND
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum AttendeeMode {
  OPEN
  INVITE_ONLY
}

enum AnnouncementAudience {
  ALL_ATTENDEES
  CHECKED_IN
  SPEAKERS
  EXHIBITORS
}

model PlatformConfig {
  id        String   @id @default("singleton")
  brandName String   @default("UoN Event Hub")
  fromName  String?
  fromEmail String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model User {
  id                      String  @id @default(cuid())
  email                   String  @unique
  passwordHash            String?
  name                    String
  role                    Role    @default(ATTENDEE)
  jobTitle                String?
  organization            String?
  bio                     String?
  avatarUrl               String?
  faculty                 String?
  studentId               String?
  phone                   String?
  showInDirectory         Boolean @default(true)
  allowConnectionRequests Boolean @default(true)
  language                String  @default("en")
  timezone                String  @default("Africa/Nairobi")

  activatedAt            DateTime?
  pendingCode            String?
  pendingCodeExpiresAt   DateTime?
  passwordResetToken     String?   @unique
  passwordResetExpiresAt DateTime?

  expiresAt   DateTime?
  suspendedAt DateTime?

  totpSecret    String?
  totpEnabledAt DateTime?

  stripeCustomerId String? @unique

  notifySessionEmail      Boolean @default(true)
  notifySessionInApp      Boolean @default(true)
  notifyMessagesEmail     Boolean @default(true)
  notifyMessagesInApp     Boolean @default(true)
  notifyConnectionsEmail  Boolean @default(true)
  notifyConnectionsInApp  Boolean @default(true)
  notifyDiscussionsEmail  Boolean @default(false)
  notifyDiscussionsInApp  Boolean @default(true)
  notifyEventUpdatesEmail Boolean @default(true)
  notifyEventUpdatesInApp Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizedEvents       Event[]               @relation("EventOrganizer")
  registrations         Registration[]
  sessionRegistrations  SessionRegistration[]
  speakerProfile        Speaker?
  postedDiscussions     Discussion[]          @relation("DiscussionAuthor")
  discussionReplies     DiscussionReply[]
  sentConnections       Connection[]          @relation("ConnectionRequester")
  receivedConnections   Connection[]          @relation("ConnectionReceiver")
  sentMessages          Message[]             @relation("MessageSender")
  receivedMessages      Message[]             @relation("MessageReceiver")
  notifications         Notification[]
  chatMessages          ChatMessage[]
  authoredAnnouncements Announcement[]        @relation("AnnouncementAuthor")
  auditEntries          AuditLog[]            @relation("AuditActor")
  surveyResponses       EventSurveyResponse[]
  payments              Payment[]
  pollVotes             PollVote[]
  questionsAsked        Question[]
  questionUpvotes       QuestionUpvote[]
  exhibitorMemberships  ExhibitorMember[]
  capturedAsLead        Lead[]                @relation("LeadAttendee")
  capturedLeads         Lead[]                @relation("LeadCapturer")
  pushSubscriptions     PushSubscription[]
  waitlistEntries       WaitlistEntry[]
  meetingsRequested     MeetingRequest[]      @relation("MeetingRequester")
  meetingsReceived      MeetingRequest[]      @relation("MeetingRecipient")
}

model Event {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  tagline      String?
  description  String
  startDate    DateTime
  endDate      DateTime
  timezone     String       @default("Africa/Nairobi")
  venue        String?
  coverImage   String?
  logoUrl      String?
  status       EventStatus  @default(PUBLISHED)
  attendeeMode AttendeeMode @default(INVITE_ONLY)
  organizerId  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  organizer        User                @relation("EventOrganizer", fields: [organizerId], references: [id])
  sessions         Session[]
  speakers         Speaker[]
  exhibitors       Exhibitor[]
  pages            CustomPage[]
  registrations    Registration[]
  discussions      Discussion[]
  notifications    Notification[]
  knowledgeBase    EventKnowledgeBase?
  chatMessages     ChatMessage[]
  invites          AttendeeInvite[]
  announcements    Announcement[]
  survey           EventSurvey?
  slugAliases      SlugAlias[]
  ticketTypes      TicketType[]
  promoCodes       PromoCode[]
  payments         Payment[]
  polls            Poll[]
  questions        Question[]
  waitlist         WaitlistEntry[]
  webhooks         Webhook[]
  meetings         MeetingRequest[]
  emailAutomations EmailAutomation[]
}

model SlugAlias {
  id        String   @id @default(cuid())
  slug      String   @unique
  eventId   String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Session {
  id          String        @id @default(cuid())
  eventId     String
  title       String
  description String
  startTime   DateTime
  endTime     DateTime
  location    String?
  format      SessionFormat @default(IN_PERSON)
  capacity    Int?
  videoUrl    String?
  slidesUrl   String?
  notesUrl    String?
  isFeatured  Boolean       @default(false)
  track       String?
  createdAt   DateTime      @default(now())

  event         Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speakers      SessionSpeaker[]
  registrations SessionRegistration[]
  polls         Poll[]
  questions     Question[]

  @@index([eventId, startTime])
}

model Poll {
  id             String    @id @default(cuid())
  sessionId      String
  eventId        String
  question       String
  allowMultiple  Boolean   @default(false)
  isOpen         Boolean   @default(false)
  resultsVisible Boolean   @default(false)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  closedAt       DateTime?

  session Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  event   Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]

  @@index([sessionId, sortOrder])
  @@index([eventId])
}

model PollOption {
  id        String @id @default(cuid())
  pollId    String
  label     String
  sortOrder Int    @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId, optionId])
  @@index([pollId])
}

model Question {
  id        String   @id @default(cuid())
  sessionId String
  eventId   String
  userId    String
  text      String
  answered  Boolean  @default(false)
  hidden    Boolean  @default(false)
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  session Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  event   Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  upvotes QuestionUpvote[]

  @@index([sessionId, hidden, pinned, createdAt])
  @@index([eventId])
}

model QuestionUpvote {
  questionId String
  userId     String
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([questionId, userId])
  @@index([questionId])
}

model Speaker {
  id           String  @id @default(cuid())
  eventId      String
  userId       String? @unique
  name         String
  email        String?
  jobTitle     String?
  organization String?
  bio          String?
  photoUrl     String?
  linkedinUrl  String?
  twitterUrl   String?
  isKeynote    Boolean @default(false)

  event    Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User?            @relation(fields: [userId], references: [id])
  sessions SessionSpeaker[]

  @@index([eventId, email])
}

model SessionSpeaker {
  sessionId String
  speakerId String

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@id([sessionId, speakerId])
}

model Registration {
  id           String    @id @default(cuid())
  eventId      String
  userId       String
  registeredAt DateTime  @default(now())
  checkedInAt  DateTime?
  qrToken      String    @unique @default(cuid())
  ticketTypeId String?
  promoCodeId  String?
  paidCents    Int       @default(0)
  paymentId    String?   @unique

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketType TicketType? @relation(fields: [ticketTypeId], references: [id], onDelete: SetNull)
  promoCode  PromoCode?  @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  payment    Payment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([eventId, userId])
  @@index([ticketTypeId])
  @@index([promoCodeId])
}

model TicketType {
  id           String    @id @default(cuid())
  eventId      String
  name         String
  description  String?
  priceCents   Int       @default(0)
  currency     String    @default("USD")
  capacity     Int?
  soldCount    Int       @default(0)
  saleStartsAt DateTime?
  saleEndsAt   DateTime?
  sortOrder    Int       @default(0)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  event         Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations Registration[]
  payments      Payment[]
  promoCodes    PromoCode[]
  waitlist      WaitlistEntry[]

  @@index([eventId, active, sortOrder])
}

model PromoCode {
  id            String    @id @default(cuid())
  eventId       String
  code          String
  discountType  String    @default("percent")
  discountValue Int
  maxUses       Int?
  usedCount     Int       @default(0)
  validFrom     DateTime?
  validUntil    DateTime?
  ticketTypeId  String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType    TicketType?    @relation(fields: [ticketTypeId], references: [id], onDelete: SetNull)
  registrations Registration[]
  payments      Payment[]

  @@unique([eventId, code])
  @@index([eventId, active])
}

model SessionRegistration {
  id           String    @id @default(cuid())
  sessionId    String
  userId       String
  registeredAt DateTime  @default(now())
  checkedInAt  DateTime?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
}

model Exhibitor {
  id          String  @id @default(cuid())
  eventId     String
  name        String
  tagline     String?
  description String
  logoUrl     String?
  website     String?
  email       String?
  boothNumber String?
  category    String?

  event   Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  members ExhibitorMember[]
  leads   Lead[]
}

model ExhibitorMember {
  id          String   @id @default(cuid())
  exhibitorId String
  userId      String
  isOwner     Boolean  @default(false)
  createdAt   DateTime @default(now())

  exhibitor Exhibitor @relation(fields: [exhibitorId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([exhibitorId, userId])
  @@index([userId])
}

model Lead {
  id           String   @id @default(cuid())
  exhibitorId  String
  userId       String
  capturedById String
  notes        String?
  qualified    Boolean  @default(false)
  createdAt    DateTime @default(now())

  exhibitor  Exhibitor @relation(fields: [exhibitorId], references: [id], onDelete: Cascade)
  user       User      @relation("LeadAttendee", fields: [userId], references: [id], onDelete: Cascade)
  capturedBy User      @relation("LeadCapturer", fields: [capturedById], references: [id], onDelete: Cascade)

  @@unique([exhibitorId, userId])
  @@index([exhibitorId, createdAt])
}

model CustomPage {
  id        String  @id @default(cuid())
  eventId   String
  slug      String
  title     String
  body      String
  order     Int     @default(0)
  showInNav Boolean @default(true)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, slug])
}

model Discussion {
  id        String   @id @default(cuid())
  eventId   String
  authorId  String
  title     String
  body      String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  event   Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author  User              @relation("DiscussionAuthor", fields: [authorId], references: [id])
  replies DiscussionReply[]
}

model DiscussionReply {
  id           String   @id @default(cuid())
  discussionId String
  authorId     String
  body         String
  createdAt    DateTime @default(now())

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  author     User       @relation(fields: [authorId], references: [id])
}

model Connection {
  id          String           @id @default(cuid())
  requesterId String
  receiverId  String
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  respondedAt DateTime?

  requester User @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  receiverId String
  body       String
  sentAt     DateTime  @default(now())
  readAt     DateTime?

  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId, sentAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  eventId   String?
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model EventKnowledgeBase {
  id        String   @id @default(cuid())
  eventId   String   @unique
  fileName  String
  fileType  String
  fileUrl   String?
  rawText   String
  charCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId, userId, createdAt])
}

model AttendeeInvite {
  id          String    @id @default(cuid())
  eventId     String
  firstName   String
  lastName    String
  email       String
  invitedAt   DateTime  @default(now())
  activatedAt DateTime?
  emailSentAt DateTime?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
}

model Announcement {
  id             String               @id @default(cuid())
  eventId        String
  authorId       String
  title          String
  body           String
  audience       AnnouncementAudience @default(ALL_ATTENDEES)
  sendEmail      Boolean              @default(true)
  sendInApp      Boolean              @default(true)
  sentAt         DateTime?
  recipientCount Int                  @default(0)
  emailsSent     Int                  @default(0)
  emailsFailed   Int                  @default(0)
  createdAt      DateTime             @default(now())

  event  Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author User  @relation("AnnouncementAuthor", fields: [authorId], references: [id])

  @@index([eventId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  actorName  String?
  action     String
  targetType String?
  targetId   String?
  summary    String
  metadata   String?
  ip         String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

model EventSurvey {
  id          String   @id @default(cuid())
  eventId     String   @unique
  title       String
  description String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event     Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  questions EventSurveyQuestion[]
  responses EventSurveyResponse[]
}

model EventSurveyQuestion {
  id       String  @id @default(cuid())
  surveyId String
  order    Int     @default(0)
  prompt   String
  type     String
  options  String?
  required Boolean @default(false)

  survey EventSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model EventSurveyResponse {
  id          String   @id @default(cuid())
  surveyId    String
  userId      String
  answers     String
  submittedAt DateTime @default(now())

  survey EventSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([surveyId, userId])
  @@index([surveyId, submittedAt])
}

model Payment {
  id                    String    @id @default(cuid())
  userId                String
  amountCents           Int
  currency              String    @default("USD")
  status                String    @default("pending")
  description           String?
  provider              String    @default("stripe")
  kind                  String    @default("renewal")
  planId                String?
  eventId               String?
  ticketTypeId          String?
  promoCodeId           String?
  stripeSessionId       String?   @unique
  stripePaymentIntentId String?   @unique
  flutterwaveTxRef      String?   @unique
  flutterwaveTxId       String?
  metadata              String?
  createdAt             DateTime  @default(now())
  paidAt                DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         Plan?         @relation(fields: [planId], references: [id], onDelete: SetNull)
  event        Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  ticketType   TicketType?   @relation(fields: [ticketTypeId], references: [id], onDelete: SetNull)
  promoCode    PromoCode?    @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  registration Registration?

  @@index([userId, createdAt])
  @@index([planId])
  @@index([eventId])
  @@index([ticketTypeId])
}

model Plan {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  tagline       String?
  description   String
  priceCents    Int
  currency      String   @default("USD")
  billingPeriod String   @default("one_time")
  recommended   Boolean  @default(false)
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  features      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  payments Payment[]

  @@index([active, sortOrder])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WaitlistEntry {
  id           String    @id @default(cuid())
  eventId      String
  ticketTypeId String
  userId       String
  position     Int
  status       String    @default("waiting")
  notifiedAt   DateTime?
  createdAt    DateTime  @default(now())

  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ticketTypeId, userId])
  @@index([ticketTypeId, status, position])
  @@index([eventId])
}

model Webhook {
  id              String    @id @default(cuid())
  eventId         String?
  url             String
  secret          String
  events          String
  active          Boolean   @default(true)
  lastDeliveredAt DateTime?
  lastError       String?
  createdAt       DateTime  @default(now())

  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, active])
}

model MeetingRequest {
  id            String    @id @default(cuid())
  eventId       String
  requesterId   String
  recipientId   String
  proposedStart DateTime
  proposedEnd   DateTime
  status        String    @default("pending")
  location      String?
  message       String?
  createdAt     DateTime  @default(now())
  respondedAt   DateTime?

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  requester User  @relation("MeetingRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient User  @relation("MeetingRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([eventId, status])
  @@index([requesterId])
  @@index([recipientId])
}

model EmailAutomation {
  id        String   @id @default(cuid())
  eventId   String
  trigger   String
  enabled   Boolean  @default(false)
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, trigger])
}
