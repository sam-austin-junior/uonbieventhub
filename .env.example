# ── Database ───────────────────────────────────────────────────────────────
# Local development with docker-compose:
DATABASE_URL="postgresql://uon:uon_dev_password@localhost:5433/uon_event_hub?schema=public"
#
# Production (Supabase): use the "Transaction" pooler URL from
# Supabase → Project Settings → Database → Connection string → Transaction pooler.
# It looks like:
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Also set DIRECT_URL to the "Session" pooler URL on port 5432 (needed by Prisma migrate):
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# DIRECT_URL=""

# ── Auth ───────────────────────────────────────────────────────────────────
# 32+ char random string for JWT signing.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="replace-me-with-the-output-of-the-command-above"

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="UoN Event Hub"
# Used as the absolute base in email links (activation codes, announcements, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: NEXT_PUBLIC_APP_URL="https://uonbieventhub.co.ke"

# ── Chatbot (optional but recommended) ─────────────────────────────────────
# Free tier — get a key at https://console.groq.com/keys
GROQ_API_KEY=""
# Optional override (defaults to llama-3.3-70b-versatile)
# GROQ_MODEL="llama-3.3-70b-versatile"

# ── Email (Resend) ─────────────────────────────────────────────────────────
# Get a key at https://resend.com/api-keys
# Verify your sending domain at https://resend.com/domains
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"
RESEND_FROM_NAME="UoN Event Hub"

# ── File storage (Supabase Storage) ────────────────────────────────────────
# Required in production (Vercel filesystem is read-only).
# Create a public bucket called "uploads" in Supabase → Storage.
# Project URL: Supabase → Project Settings → API → Project URL
# Service role key: Supabase → Project Settings → API → service_role (secret).
# NEVER expose the service role key to the browser.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
# Optional override of the bucket name
# SUPABASE_UPLOADS_BUCKET="uploads"

# ── Cron secret ────────────────────────────────────────────────────────────
# Vercel Cron sends Authorization: Bearer $CRON_SECRET to scheduled routes.
# Generate a long random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET=""

# ── Stripe payments ────────────────────────────────────────────────────────
# Optional — when set, organizers can self-renew their plan via Stripe Checkout
# from /admin/billing. Webhook extends User.expiresAt on successful payment.
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
# Configure your webhook at https://dashboard.stripe.com/webhooks pointing at
# https://<your-domain>/api/billing/webhook with the event "checkout.session.completed"
STRIPE_WEBHOOK_SECRET=""
# Price for one renewal (in the smallest currency unit, e.g. cents/cents-of-shilling)
STRIPE_RENEWAL_PRICE_CENTS="50000"
STRIPE_CURRENCY="usd"
# How many days a successful payment extends the organizer's access for
STRIPE_RENEWAL_DAYS="365"

# ── Flutterwave payments ──────────────────────────────────────────────────
# Optional — when set, organizers can purchase plans and attendees can buy
# tickets via Flutterwave (cards, M-Pesa, mobile money, bank transfer, USSD).
# Sandbox + live keys at https://dashboard.flutterwave.com/settings/apis
FLW_SECRET_KEY=""
# Static "Secret hash" from Flutterwave → Settings → Webhooks. Must match
# what you send Flutterwave; we verify it on every incoming webhook.
FLW_WEBHOOK_HASH=""
# Webhook URL to register in the Flutterwave dashboard:
#   https://<your-domain>/api/billing/webhook/flutterwave

# ── PWA push notifications (optional) ─────────────────────────────────────
# Public + private VAPID keys for Web Push. Generate with:
#   npx web-push generate-vapid-keys
# Without these the PWA install prompt still works but push delivery doesn't.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Contact address Web Push servers can reach you at if a subscription
# misbehaves. Set to mailto:hello@yourdomain.
VAPID_SUBJECT="mailto:hello@example.com"
