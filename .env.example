# ── Database ───────────────────────────────────────────────────────────────
# Local development with docker-compose:
DATABASE_URL="postgresql://uon:uon_dev_password@localhost:5433/uon_event_hub?schema=public"
#
# Production (Supabase transaction pooler): use the pooler URL from
# Supabase → Project Settings → Database → Connection string → Transaction pooler.
# You MUST append the pgbouncer flags — Supabase's copy button doesn't.
# Prisma will otherwise cache prepared statements that collide across
# pooler-reused backend connections, throwing "prepared statement s0
# already exists" on every second request.
#   postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#
# Also set DIRECT_URL to the same host on port 5432 (no query string) —
# Prisma Migrate needs long-lived connections that pgbouncer doesn't allow.
# DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres"

# ── Auth ───────────────────────────────────────────────────────────────────
# 32+ char random string for JWT signing.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="replace-me-with-the-output-of-the-command-above"

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="UoN Event Hub"
# Used as the absolute base in email links (activation codes, announcements, etc.)
# In production, prefer the "www" version — apex 308-redirects add a hop.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: NEXT_PUBLIC_APP_URL="https://www.uonbieventhub.co.ke"

# ── Chatbot + AI networking matcher (optional but recommended) ─────────────
# Free tier — get a key at https://console.groq.com/keys
# Powers the per-event AI chatbot AND the AI-ranked "People you should meet"
# recommendations on /e/<slug>/attendees.
GROQ_API_KEY=""
# Optional override (defaults to llama-3.3-70b-versatile)
# GROQ_MODEL="llama-3.3-70b-versatile"

# ── Email (Resend) ─────────────────────────────────────────────────────────
# Get a key at https://resend.com/api-keys
# Verify your sending domain at https://resend.com/domains
# Also powers the per-event email automations (registration confirmation,
# check-in, ticket purchase, waitlist joined, meeting requested/accepted).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"
RESEND_FROM_NAME="UoN Event Hub"

# ── File storage (Supabase Storage) ────────────────────────────────────────
# Required in production (Vercel filesystem is read-only).
# Create a public bucket called "uploads" in Supabase → Storage.
# Project URL: Supabase → Project Settings → API → Project URL
# Service role key: Supabase → Project Settings → API → service_role (secret).
# NEVER expose the service role key to the browser.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
# Optional override of the bucket name
# SUPABASE_UPLOADS_BUCKET="uploads"

# ── Cron secret ────────────────────────────────────────────────────────────
# Vercel Cron sends Authorization: Bearer $CRON_SECRET to scheduled routes.
# Generate a long random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET=""

# ── Stripe payments (optional) ─────────────────────────────────────────────
# When set, organizers can renew their plan or sell paid tickets via Stripe
# Checkout. Webhook completes payments and extends organizer expiry / creates
# ticketed Registrations.
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
# Webhook endpoint: https://<your-domain>/api/billing/webhook
# Listen for: checkout.session.completed, checkout.session.expired,
#             payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=""
# Price for the default renewal SKU (smallest currency unit, e.g. cents).
# Only relevant if you also use the plans/renewal path.
STRIPE_RENEWAL_PRICE_CENTS="50000"
STRIPE_CURRENCY="usd"
# How many days a successful renewal extends organizer access for.
STRIPE_RENEWAL_DAYS="365"

# ── Flutterwave payments (optional) ────────────────────────────────────────
# Provides the multi-currency + M-Pesa + mobile-money + card checkout used
# on plan renewal AND ticket purchase. Enables the "Flutterwave" option on
# /admin/billing and /e/<slug>/tickets.
# Get keys at https://dashboard.flutterwave.com/settings/apis
FLW_SECRET_KEY=""
# Any string you choose — set it to the same value in
# Flutterwave → Settings → Webhooks → Secret hash.
# Webhook endpoint: https://<your-domain>/api/billing/webhook/flutterwave
FLW_WEBHOOK_HASH=""

# ── Web push notifications (optional) ──────────────────────────────────────
# Enables the PWA "Turn on notifications" prompt on /e/<slug>/*. When set,
# the browser subscribes to push and stores the subscription in the
# PushSubscription table — dispatch itself is TODO (wire up web-push
# whenever you want to actually deliver notifications).
# Generate a VAPID keypair:
#   npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:eventhub@yourdomain.com"
